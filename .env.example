# API Keys
ANTHROPIC_API_KEY=

# Gemini: use GEMINI_API_KEY para uma key ou GEMINI_API_KEYS para múltiplas (vírgula-separado)
# GEMINI_API_KEYS habilita o pool round-robin com paralelismo proporcional ao número de keys
GEMINI_API_KEY=
GEMINI_API_KEYS=key1,key2,key3

# Adobe PDF Services (OCR para PDFs escaneados)
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# Database (SQLite default, PostgreSQL para produção)
DATABASE_URL=sqlite:///data.db

# Upload
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE_MB=50